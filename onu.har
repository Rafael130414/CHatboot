yle.color = '#000000';\r\n\t\t}\r\n\t}\r\n\t\r\n\tobjTR.style.backgroundColor = '#B7E3E3';//c7e7fe\r\n\tfor (var i = 0; i < objTR.cells.length; i++)\r\n\t{\r\n\t\tobjTR.cells[i].style.color = '#000000';\r\n\t}\r\n}\r\n\r\nfunction clearInputValue(id)\r\n{\r\n\tvar node = getElement(id);\r\n\tnode.value = \"\";\r\n}\r\n\r\nfunction resetInputValue(id)\r\n{\r\n\tvar node = getElement(id);\r\n\tif(node.value == \"\")\r\n\t\tnode.value = node.defaultValue;\r\n}\r\n\r\nfunction clearZeroInputValue(id)\r\n{\r\n\tvar node = getElement(id);\r\n\tif(node.value == \"0\" || node.value == \"0.0.0.0\")\r\n\t\tnode.value = \"\";\r\n}\r\n\r\nfunction waitToLogin(ispName, curUserType)\r\n{\r\n\tsetTimeout(function(){toLogin(ispName,curUserType)}, 180000);\r\n}\r\n\r\nfunction toLogin(ispName, curUserType) \r\n{\r\n\tvar loc = '/login.html';\r\n\tif(ispName == '3' && curUserType == '2')\t//X_CU Admintstrator\r\n\t\tloc = '/cu.html';\r\n\r\n//\tvar code = 'window.parent.location=\"' + loc + '\"';\r\n//\teval(code);\r\n\ttop.location = loc;\r\n}\r\n\r\n/*****************************************************************************\r\n * function name  :     setCookie\r\n * Responsible person :\r\n * Creation data   : 2016-4-25\r\n * Function function  :  Setting cookies for BROWSER through JS\r\n\r\n * Input parameters  : \r\n                   name :  cookie name\r\n\t\t\t\t  value:   cookie  value\r\n                   iDay express expiration time  ( < 0 , =0  >0 three conditions ) , =0  means delete \r\n\r\n\t\t\t         path :   cookie Applicable access path\r\n * Output parameters  : none\r\n * return  : \r\n * Call relationship  : \r\n * others  : \r\n\r\n*****************************************************************************/\r\nfunction setCookie(name, value, iDay,path)\r\n{   \r\n    /* iDay  express expiration time: in cookie = means append,not assignment  */   \r\n    var oDate=new Date();   \r\n\r\n    oDate.setDate(oDate.getDate()+iDay);      \r\n\t\r\n    document.cookie = name+'='+value+';expires='+oDate+';path='+path;\r\n\r\n}\r\n\r\n/*****************************************************************************\r\n * function name  :    removeCookie\r\n * Responsible person :\r\n * Creation data   : 2016-4-25\r\n * Function function  :  remove cookies for BROWSER through JS\r\n\r\n * Input parameters  : \r\n                     name :  cookie name\r\n\t\t\t         path :   cookie Applicable access path\r\n * Output parameters  : none\r\n * return  : \r\n * Call relationship  : \r\n * others  : \r\n\r\n*****************************************************************************/\r\nfunction removeCookie(name, path)\r\n{   \r\n    /* delete after i day expires  */     \r\n    setCookie(name, \"\", -1, path);//modify by wuxj, 20160510, Solve the problem that the cookie is not properly expired and submitted to the background, causing the forms process to be verified as not logged in.\r\n//    setCookie(name, 1, -1, path);\r\n\r\n}\r\n\r\nfunction clearOptions(colls)\r\n{\r\n\tvar length = colls.length;\r\n\tfor(var i = length - 1; i >= 0; i--)\r\n\t{\r\n\t\tcolls.remove(i);\r\n\t}\r\n}\r\n\r\nfunction len(s) { \r\n\tvar l = 0; \r\n\tvar a = s.split(\"\"); \r\n\tfor (var i=0;i<a.length;i++) { \r\n\t\tif (a[i].charCodeAt(0)<299) { \r\n\t\t\tl++; \r\n\t\t} else { \r\n\t\t\tl+=2; \r\n\t\t} \r\n\t} \r\n\treturn l; \r\n}\r\n\r\nfunction space2null(str)\r\n{\r\n\tif(str == \" \")\r\n\t\treturn \"\";\r\n\telse\r\n\t\treturn str;\r\n}\r\n\r\n function updateForms() { \r\n    // Get all form elements in the page\r\n    var forms = document.getElementsByTagName('form'); \r\n    for(i=0; i<forms.length; i++) { \r\n        var url = forms[i].action; \r\n\r\n        // If the action value of this form is empty,  csrftoken is not added. \r\n        if(url == null || url == \"\" ) continue; \r\n\r\n        // Generate input elements dynamically and add them after form\r\n        var e = document.createElement(\"input\"); \r\n        e.name = \"csrftoken\"; \r\n\t\te.value = getCsrftoken();\r\n        e.type=\"hidden\"; \r\n        forms[i].appendChild(e); \r\n    } \r\n }\r\n\r\nfunction getCookie(c_name)\r\n{\r\n\tif (document.cookie.length>0)\r\n\t{\r\n\t\tc_start=document.cookie.indexOf(c_name + \"=\")\r\n\t\tif (c_start!=-1)\r\n\t\t{ \r\n\t\t\tc_start=c_start + c_name.length+1 \r\n\t\t\tc_end=document.cookie.indexOf(\";\",c_start)\r\n\t\t\tif (c_end==-1) c_end=document.cookie.length\r\n\t\t\treturn unescape(document.cookie.substring(c_start,c_end))\r\n\t\t} \r\n\t}\r\n\treturn \"\"\r\n}\r\n\r\nfunction getCsrftoken()\r\n{\r\n\tvar str;\r\n\tif (typeof(token) !== \"undefined\")\r\n\t{\r\n\t\tstr = token;\r\n\t} else {\r\n//\t\tstr = getCookie(\"fhstamp\");\r\n\t\tstr = '';\r\n\t}\r\n\treturn str;\r\n}\r\n\r\nfunction html_decode(input)\r\n{\r\n\tvar output = \"\";\r\n\tif(input.length == 0)\r\n\t\treturn \"\";\r\n\toutput = input.replace(/\\&lt;/g, '<');\r\n\toutput = output.replace(/\\&gt;/g, '>');\r\n\toutput = output.replace(/\\&amp;/g, '&');\r\n\toutput = output.replace(/\\&#34;/g, '\"');\r\n\toutput = output.replace(/\\&#39;/g, '\\'');\r\n\toutput = output.replace(/\\&#32;/g, ' ');\r\n\treturn output;\r\n}\r\n\r\nfunction load_waiting() {\r\n\tvar node = parent.getElementById(\"load\");\r\n\tnode.style.display = \"\";\r\n}\r\n\r\nfunction load_finish() {\r\n\tvar node;\r\n\tvar str = parent.location.href;\r\n\tif(str.search(\"/menu.html\") == -1)//not menu.html\r\n\t{\r\n\t\tnode = parent.getElementById(\"load\");\r\n\t\tif(!(null === node))\r\n\t\t\tnode.style.display = \"none\";\r\n\t}\r\n}\r\n\r\nfunction changeipAddress(str)\r\n{\r\n\treturn str.replace(/axs@o/g, '.')\r\n}\r\n\r\nfunction encodeIPAddress(input)\r\n{\r\n\tvar output = \"\";\r\n\tif(input.length == 0)\r\n\t\treturn \"\";\r\n\toutput = input.replace(/\\./g, 'axs@o');\r\n\treturn output;\r\n}\r\n\r\n"
