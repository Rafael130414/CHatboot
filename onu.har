            "text": "<po>\r\n  <message msgid=\"inet apply\" msgstr=\"Apply\" />\r\n  <message msgid=\"inet cancel\" msgstr=\"Cancel\" />\r\n  <message msgid=\"inet enable\" msgstr=\"Enable\" />\r\n  <message msgid=\"inet disable\" msgstr=\"Disable\" />\r\n\r\n  <message msgid=\"inet mac\" msgstr=\"MAC Address\" />\r\n  <message msgid=\"inet ip\" msgstr=\"IP Address\" />\r\n  <message msgid=\"gateway_ip\" msgstr=\"Lan Interface\" />\r\n  <message msgid=\"inet server\" msgstr=\"Server IP\" />\r\n  <message msgid=\"inet netmask\" msgstr=\"Subnet Mask\" />\r\n  <message msgid=\"inet lan2\" msgstr=\"LAN2\" />\r\n  <message msgid=\"inet lan2 ip\" msgstr=\"LAN2 IP Address\" />\r\n  <message msgid=\"inet lan2 netmask\" msgstr=\"LAN2 Subnet Mask\" />\r\n  <message msgid=\"inet gateway\" msgstr=\"Default Gateway\" />\r\n  <message msgid=\"inet pri dns\" msgstr=\"Primary DNS Server\" />\r\n  <message msgid=\"inet sec dns\" msgstr=\"Secondary DNS Server\" />\r\n  <message msgid=\"inet user\" msgstr=\"User Name\" />\r\n  <message msgid=\"inet password\" msgstr=\"Password\" />\r\n  <message msgid=\"inet pass2\" msgstr=\"Verify Password\" />\r\n  <message msgid=\"inet hostname\" msgstr=\"Hostname\" />\r\n  \r\n  <message msgid=\"mtu_IllegalAlert\" msgstr=\"MTU value error! Please check MTU value again.\" />\r\n  <message msgid=\"mtudhcpstatic_IllegalAlert\" msgstr=\"MTU value error, please confirm MTU value between 1280 - 1500.\" />\r\n  <message msgid=\"mtupppoe_IllegalAlert\" msgstr=\"MTU value error, please confirm MTU value between 1280 - 1492.\" />\r\n\r\n  <message msgid=\"ipv6_dhcp_prompt\" msgstr=\"You may enable/disable IPv6 networking functions and configure IPv6 Addr as your wish, and it will take effect after restarting.\"/>\r\n  <message msgid=\"ipv6_dns_prompt\" msgstr=\"You may configure IPv6 DNS Proxy as your wish,and it will take effect after restarting.\"/>\r\n  <message msgid=\"ipv6_prefix_prompt\" msgstr=\"You may configure IPv6 Prefix Mode as your wish,and it